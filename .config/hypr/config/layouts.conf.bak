
# --- dwindle.conf ---
# ╔═══════════════════════════════════════════════════════════════════╗
# ║                         Dwindle Layout                           ║
# ╚═══════════════════════════════════════════════════════════════════╝
# Configuration for the dwindle tiling layout

dwindle {
    # Master switch for pseudotiling
    pseudotile = true
    
    # Preserve split ratio when moving windows
    preserve_split = true
    
    # Split direction behavior
    # 0 = cursor position, 1 = always left/top, 2 = always right/bottom
    force_split = 0
    
    # Smart splitting based on cursor position
    smart_split = false
    
    # Smart resizing based on cursor position
    smart_resizing = true
}


# --- master.conf ---
# ╔═══════════════════════════════════════════════════════════════════╗
# ║                          Master Layout                           ║
# ╚═══════════════════════════════════════════════════════════════════╝
# Configuration for the master layout

master {
    # New windows become master
    new_status = master
    
    # New windows appear on top
    new_on_top = true
    
    # Allow small split ratio
    allow_small_split = false
    
    # Always center master window
   #  always_center_master = false
}

